<section xml:id="lesson-12-13">
  <title>Lessons 12 and 13</title>

  <objectives>
    <ul>
      <li>Create polynomial functions from given zeros.</li>
      <li>Find all zeros of a polynomial function.</li>
      <li>Use the Rational Root Theorem to list possible rational zeros.</li>
      <li>Use Descartes’ Rule of Signs to analyze possible real zeros.</li>
      <li>Analyze polynomial graphs using zeros, multiplicity, and end behavior.</li>
    </ul>
  </objectives>

  <subsection xml:id="l12-creating-polynomials">
    <title>Creating Polynomials from Zeros</title>

    <exercise xml:id="l12-ex1">
      <statement>
        <p>Create a third degree polynomial with zeros <m>-2</m>, <m>-9</m>, and <m>4</m>.</p>
      </statement>
    </exercise>

    <exercise xml:id="l12-ex2">
      <statement>
        <p>
          Find a fourth degree polynomial with zeros <m>i</m> and <m>1 + 2i</m>.
        </p>
      </statement>
    </exercise>
  </subsection>

  <subsection xml:id="l12-finding-zeros">
    <title>Finding Zeros of Polynomials</title>

    <exercise xml:id="l12-ex3">
      <statement>
        <p>
          Find all zeros of
          <m>f(x) = 2x^4 + 5x^3 + 5x^2 + 20x - 12</m>
          if it is known that <m>2i</m> is a zero.
        </p>
      </statement>
    </exercise>

    <exercise xml:id="l12-ex4">
      <statement>
        <p>
          Solve <m>-3x^3 + 15x^2 - 6x - 24 = 0</m> for all real solutions.
        </p>
      </statement>
    </exercise>
  </subsection>

  <subsection xml:id="l13-rational-roots">
    <title>The Rational Root Theorem</title>

    <exercise xml:id="l13-ex1">
      <statement>
        <p>
          List only (do not solve) the possible rational roots of
          <m>x^3 + 3x^2 - 4 = 0</m>.
        </p>
      </statement>
    </exercise>
  </subsection>

  <subsection xml:id="l13-descartes">
    <title>Descartes’ Rule of Signs</title>

    <exercise xml:id="l13-ex2">
      <statement>
        <p>
          Use Descartes’ Rule of Signs to determine the possible number of
          positive and negative real zeros of
          <m>x^3 + 3x^2 - 4 = 0</m>.
        </p>
      </statement>
    </exercise>
  </subsection>

  <subsection xml:id="l13-polynomial-analysis">
    <title>Polynomial Analysis</title>

    <exercise xml:id="l13-ex3">
      <statement>
        <p>For <m>f(x) = x^3 + 3x^2 - 4</m>:</p>
        <ol marker="a.">
          <li>
            Determine the zeros, give the multiplicity, and determine whether
            the function crosses or touches the <m>x</m>-axis at each zero.
          </li>
          <li>Determine the end behavior of the graph of <m>f(x)</m>.</li>
          <li>
            Determine where the function is above the <m>x</m>-axis and where
            the function is below the <m>x</m>-axis.
          </li>
          <li>Determine the <m>y</m>-intercept.</li>
          <li>Graph the function.</li>
        </ol>
      </statement>
    </exercise>
  </subsection>

</section>