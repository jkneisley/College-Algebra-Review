            <description><p>Graph used to determine whether it represents a function.</p></description>
          </image>
        </figure>
      </statement>
      <solution>
        <p>Justifications based on the vertical line test.</p>
      </solution>
    </exercise>

  <exercise xml:id="l1-ex4">
      <statement>
        <p>The graph of a function <m>f</m> is given below. Use it to find each indicated value.</p>

        <figure>
          <caption>Graph of a function used for evaluation.</caption>
          <image source="../figures/feval-review.png">
            <description><p>Graph of a function used for evaluation.</p></description>
          </image>
        </figure>

        <ol marker="a.">
          <li><m>f(-8)</m></li>
          <li><m>f(-4)</m></li>
          <li><m>f(15)</m></li>
          <li>Find <m>x</m> if <m>f(x)=8</m></li>
        </ol>
      </statement>
      <solution>
        <p>Values read directly from the graph.</p>
      </solution>
    </exercise>
</section>